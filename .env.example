# Copie para .env (git-ignored) e ajuste se quiser: cp .env.example .env
# Usado pelo docker-compose (serviço postgres) e pela API/Drizzle.

POSTGRES_USER=bamboo
POSTGRES_PASSWORD=bamboo
POSTGRES_DB=bamboo
POSTGRES_PORT=5432

# Connection string consumida pela API e pelo drizzle-kit.
DATABASE_URL=postgresql://bamboo:bamboo@localhost:5432/bamboo
